# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=lsv2-...
LANGCHAIN_PROJECT="propylon-sweng-group16"

# Propylon Services
ELASTICSEARCH_URL=http://elasticsearch:9200
# OpenSearch (Legacy - being replaced by ElasticSearch in backend-dev)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# LLM SWITCHING
LLM_PROVIDER=hf
LLM_MODEL=distilgpt2

HF_SERVER_URL=http://localhost:8002

NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1


# Ingestion & Search (from backend-dev)
SEARCH_BACKEND=elasticsearch 
INDEX_NAME=legislation_chunks
SEARCH_LIMIT=10
STATE_CODE=TX
CONGRESS_NUMBER=118
CONGRESS_GOV_API_KEY=api_key_here
